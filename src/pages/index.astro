---
// src/pages/index.astro
// PQHorizon landing page. SEO tags are kept inline here (not delegated to the
// Layout) so the technical-SEO regression check in src/__tests__/seo.test.js —
// which reads this file raw — keeps passing. The interactive page body is
// ported from genai/src/routes/index.tsx and mounts as an Astro island.
import "../styles/global.css";
import LandingPage from "../components/LandingPage.tsx";

const site = "https://pqhorizon.com";
const title = "PQHorizon — Post-Quantum Crypto Readiness";
const description =
  "Free post-quantum TLS preview. See what breaks before your auditor asks — built for teams facing the 2029 PQ migration deadline.";
// Canonical MUST match the served URL incl. trailing slash (trailingSlash:
// 'always' in astro.config.mjs). A no-slash canonical 308-redirects and breaks
// indexing (CHECK_161).
const canonical = `${site}/`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0d1418" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="PQHorizon" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts (ported from genai/src/routes/__root.tsx) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />

    <!-- JSON-LD structured data: Organization + WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://pqhorizon.com/#organization",
          "name": "PQHorizon",
          "url": "https://pqhorizon.com/"
        },
        {
          "@type": "WebSite",
          "@id": "https://pqhorizon.com/#website",
          "url": "https://pqhorizon.com/",
          "name": "PQHorizon",
          "publisher": { "@id": "https://pqhorizon.com/#organization" }
        }
      ]
    })} />
  </head>
  <body>
    <LandingPage client:load />
  </body>
</html>
