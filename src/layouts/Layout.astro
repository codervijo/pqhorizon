---
// src/layouts/Layout.astro
// Shared chrome ported from genai/src/routes/__root.tsx (head/meta, fonts,
// theme-color, global stylesheet). Interactive page bodies mount as Astro
// islands from within the <slot />.
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const site = "https://pqhorizon.com";
const {
  title = "PQHorizon — Post-Quantum Crypto Readiness",
  description = "See what breaks before your auditor asks. Free post-quantum TLS preview and full cryptographic inventory for teams facing the 2029 deadline.",
  canonical = `${site}/`,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0d1418" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="PQHorizon" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Fonts (ported from __root.tsx) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
